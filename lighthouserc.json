{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080",
        "http://localhost:8080/dashboard",
        "http://localhost:8080/fleet-dashboard",
        "http://localhost:8080/drivers"
      ],
      "staticDistDir": "./dist",
      "numberOfRuns": 3,
      "settings": {
        "configPath": "./lighthouse-config.js",
        "chromeFlags": "--no-sandbox"
      },
      "headless": true,
      "chrome": {
        "disable": [
          "site-per-process"
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage",
      "outputDir": "./.lighthouse"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.80,
            "maxNumericValue": 5000
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.80
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 4000
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "first-input-delay": [
          "error",
          {
            "maxNumericValue": 300
          }
        ],
        "first-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ],
        "speed-index": [
          "error",
          {
            "maxNumericValue": 4000
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 300
          }
        ],
        "unused-css": [
          "warn",
          {
            "maxNumericValue": 100000
          }
        ],
        "unused-javascript": [
          "warn",
          {
            "maxNumericValue": 200000
          }
        ]
      }
    }
  }
}
