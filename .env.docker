# ============================================================================
# Docker Environment Configuration
# ============================================================================

# Node Environment
NODE_ENV=production

# Database Configuration
DB_NAME=fleet_db
DB_USER=fleet_user
DB_PASSWORD=fleet_password
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://fleet_user:fleet_password@postgres:5432/fleet_db
DB_WEBAPP_POOL_SIZE=30

# Redis Configuration
REDIS_URL=redis://redis:6379

# API Configuration
PORT=3001
VITE_API_URL=http://localhost

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Authentication (if using Azure AD)
SKIP_AUTH=true
DEV_USER_UUID=00000000-0000-0000-0000-000000000001
DEV_TENANT_ID=8e33a492-9b42-4e7a-8654-0572c9773b71

# Logging
LOG_LEVEL=info

# Application Name
APP_NAME=Fleet CTA

# Timezone
TZ=UTC
